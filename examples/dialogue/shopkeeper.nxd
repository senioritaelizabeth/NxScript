# examples/dialogue/shopkeeper.nxd

var shopOpen = true
var reputation = 10

func greet
    Shopkeeper: Welcome, traveler.
    Shopkeeper: Looking for supplies?
end

@greet

if (reputation >= 20)
    Shopkeeper: For you, special prices.
else
    Shopkeeper: Earn my trust first.
end

if (shopOpen)
    @openShop
else
    Shopkeeper: We are closed.
end
