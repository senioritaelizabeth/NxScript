{
  "name": "NxScript",
  "scopeName": "source.nxscript",
  "fileTypes": ["nx"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#func-declaration" },
    { "include": "#class-declaration" },
    { "include": "#class-reference" },
    { "include": "#function-call" },
    { "include": "#builtin-functions" },
    { "include": "#type-hint" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.nxscript",
          "match": "#.*$"
        },
        {
          "name": "comment.block.nxscript",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.nxscript" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.nxscript" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nxscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.nxscript", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.nxscript",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.nxscript", "match": "\\\\." }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nxscript",
          "match": "\\b(if|else|elseif|while|for|in|return|break|continue|try|catch|throw)\\b"
        },
        {
          "name": "keyword.declaration.nxscript",
          "match": "\\b(let|var|const|func|fn|fun|function|class|extends|import|i)\\b"
        },
        {
          "name": "keyword.other.nxscript",
          "match": "\\b(new|this)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.nxscript",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.nxscript",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "func-declaration": {
      "patterns": [
        {
          "match": "\\b(func|fn|fun|function)\\s+([a-zA-Z_][a-zA-Z0-9_]*|new)",
          "captures": {
            "1": { "name": "keyword.declaration.nxscript" },
            "2": { "name": "entity.name.function.nxscript" }
          }
        }
      ]
    },
    "class-declaration": {
      "patterns": [
        {
          "match": "\\b(class)\\s+([A-Za-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.nxscript" },
            "2": { "name": "entity.name.type.class.nxscript" }
          }
        }
      ]
    },
    "class-reference": {
      "patterns": [
        {
          "name": "entity.name.type.class.nxscript",
          "match": "\\b[A-Z][A-Za-z0-9_]*(?:\\.[A-Z][A-Za-z0-9_]*)*\\b"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.nxscript" },
            "2": { "name": "punctuation.definition.paren.nxscript" }
          }
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.nxscript",
          "match": "\\b(trace|print|println|len|type|typeof|int|float|str|bool|abs|floor|ceil|round|sqrt|pow|sin|cos|tan|min|max|random|clamp|lerp|push|pop|range|contains|keys|values|upper|lower|trim|split|join)(?=\\s*\\()"
        }
      ]
    },
    "type-hint": {
      "patterns": [
        {
          "match": ":\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.nxscript" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.nxscript",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.nxscript",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.nxscript",
          "match": "\\+=|-=|\\*=|/=|%=|="
        },
        {
          "name": "keyword.operator.increment.nxscript",
          "match": "\\+\\+|--"
        },
        {
          "name": "keyword.operator.arithmetic.nxscript",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.bitwise.nxscript",
          "match": "&|\\||\\^|~|<<|>>"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.separator.comma.nxscript",     "match": "," },
        { "name": "punctuation.accessor.nxscript",            "match": "\\." },
        { "name": "punctuation.definition.block.nxscript",    "match": "[{}]" },
        { "name": "punctuation.definition.bracket.nxscript",  "match": "[\\[\\]]" },
        { "name": "punctuation.definition.paren.nxscript",    "match": "[()]" },
        { "name": "punctuation.separator.colon.nxscript",     "match": ":" }
      ]
    }
  }
}
